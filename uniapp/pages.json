{
	"pages": [{
			"path": "pages/index/index",
			"style": {
				"navigationBarTitleText": "拼个场"
			}
		},
		{
			"path": "pages/venue/list",
			"style": {
				"navigationBarTitleText": "场馆列表"
			}
		},
		{
			"path": "pages/user/profile",
			"style": {
				"navigationBarTitleText": "我的"
			}
		}
	],
	"subPackages": [{
		"root": "subpkg",
		"pages": [{
				"path": "match/detail",
				"style": {
					"navigationBarTitleText": "场局详情"
				}
			},
			{
				"path": "match/create",
				"style": {
					"navigationBarTitleText": "创建场局"
				}
			},
			{
				"path": "venue/detail",
				"style": {
					"navigationBarTitleText": "场馆详情"
				}
			},
			{
				"path": "user/matches",
				"style": {
					"navigationBarTitleText": "我参与的场局"
				}
			},
			{
				"path": "user/orders",
				"style": {
					"navigationBarTitleText": "我的订单"
				}
			},
			{
				"path": "user/credit",
				"style": {
					"navigationBarTitleText": "信用记录"
				}
			},
			{
				"path": "user/notifications",
				"style": {
					"navigationBarTitleText": "消息通知"
				}
			},
			{
				"path": "user/edit",
				"style": {
					"navigationBarTitleText": "编辑资料"
				}
			},
			{
				"path": "user/report",
				"style": {
					"navigationBarTitleText": "举报"
				}
			},
			{
				"path": "user/feedback",
				"style": {
					"navigationBarTitleText": "意见反馈"
				}
			},
			{
				"path": "login/index",
				"style": {
					"navigationBarTitleText": "登录"
				}
			}
		]
	}],
	"preloadRule": {
		"pages/index/index": {
			"network": "all",
			"packages": ["subpkg"]
		}
	},
	"globalStyle": {
		"navigationBarTextStyle": "black",
		"navigationBarTitleText": "拼个场",
		"navigationBarBackgroundColor": "#FFFFFF",
		"backgroundColor": "#F5F5F5"
	},
	"tabBar": {
		"color": "#999999",
		"selectedColor": "#409EFF",
		"borderStyle": "black",
		"backgroundColor": "#FFFFFF",
		"list": [{
				"pagePath": "pages/index/index",
				"text": "首页",
				"iconPath": "static/tabbar/home.png",
				"selectedIconPath": "static/tabbar/home-active.png"
			},
			{
				"pagePath": "pages/venue/list",
				"text": "场馆",
				"iconPath": "static/tabbar/venue.png",
				"selectedIconPath": "static/tabbar/venue-active.png"
			},
			{
				"pagePath": "pages/user/profile",
				"text": "个人中心",
				"iconPath": "static/tabbar/user.png",
				"selectedIconPath": "static/tabbar/user-active.png"
			}
		]
	},
	"easycom": {
		"autoscan": true,
		"custom": {
			"^u-(.*)": "@/components/u-$1/u-$1.vue"
		}
	}
}