{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "node",
		"strict": true,
		"jsx": "preserve",
		"resolveJsonModule": true,
		"esModuleInterop": true,
		"lib": ["ES2020", "DOM", "DOM.Iterable"],
		"skipLibCheck": true,
		"noEmit": true,
		"allowImportingTsExtensions": true,
		"baseUrl": ".",
		"paths": {
			"@/*": ["./*"]
		},
		"types": ["@dcloudio/types"]
	},
	"include": [
		"**/*.ts",
		"**/*.d.ts",
		"**/*.vue"
	],
	"exclude": [
		"node_modules",
		"uni_modules"
	]
}